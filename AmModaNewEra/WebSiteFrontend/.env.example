# Adres bazowy API (PHP). Pusty = względna ścieżka (ta sama domena).
# W developmencie np. gdy backend działa na innym porcie:
# VITE_API_BASE=http://localhost:8080

# Public site origin for index.html (canonical, og:url, og:image). No trailing slash.
# Used at build time by quasar.config.js (defaults to https://ammoda.pl).
# SITE_ORIGIN=https://staging.example.com
