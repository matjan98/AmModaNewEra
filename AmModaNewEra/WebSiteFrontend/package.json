{
  "name": "ammoda",
  "version": "0.0.1",
  "description": "A&M Moda Damska – butik online z modą damską. Nowe kolekcje, sukienki, komplety, bluzki i dodatki. Sprawdź nowości i promocje.",
  "productName": "A&M Moda Damska Kozy | Sukienki, komplety, moda damska",
  "author": "Mateusz <mateusz@urmate.ai>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "test": "echo \"No test specified\" && exit 0",
    "ui:test": "playwright test",
    "ui:update": "playwright test --update-snapshots",
    "sync:favicon": "node ./scripts/sync-favicon.mjs",
    "gen:seo": "node ./scripts/gen-seo-files.mjs",
    "dev": "npm run sync:favicon && npm run gen:seo && quasar dev",
    "build": "npm run sync:favicon && npm run gen:seo && quasar build",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.4",
    "@unhead/vue": "^3.1.4",
    "photoswipe": "^5.4.4",
    "quasar": "^2.16.0",
    "vue": "^3.5.22",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@playwright/test": "^1.55.0",
    "@prerenderer/renderer-puppeteer": "^1.2.4",
    "@prerenderer/rollup-plugin": "^0.3.12",
    "@quasar/app-vite": "^2.1.0",
    "autoprefixer": "^10.4.2",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.4.0",
    "postcss": "^8.4.14",
    "serve": "^14.2.4",
    "sharp": "^0.34.5",
    "vite-plugin-checker": "^0.11.0",
    "vue-eslint-parser": "^10.2.0"
  },
  "engines": {
    "node": ">=20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  },
  "browserslist": [
    "chrome >= 115",
    "firefox >= 115",
    "safari >= 14",
    "edge >= 115"
